1. Create 2 tables called Students and College. Students table should have std_id,std_name,course and College table should have std_id,college_id,college_name. 
Insert appropriate values in it.
Write Outer Join query for this 2 tables by means of std_id column and display the result.

create table students(std_id int, std_name varchar(50), course varchar(50));
create table college(std_id int, college_id int, college_name varchar(100));
insert into students values(1, 'saro', 'B.E CSE'),(2, 'babu', 'B.E Mech'), (3, 'indu', 'B.E ECE');
insert into college values(1, 12, 'P.B College'),(2, 13, 'Kings College'),(3, 14, 'Alpha College');

select * from students s left join college c on s.std_id = c.std_id
union
select * from students s right join college c on s.std_id = c.std_id;


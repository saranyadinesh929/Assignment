Create 2 tables shopping and order.
shopping should have columns like product_name,product_id,price
Order should have columns like product_id,order_status,shipping_detail
Join (Left,Right,Inner and Outer Join) this 2 tables based on product_id and display the result.


create table shopping(product_name varchar(100), product_id int, price decimal(10,2));
create table orders (product_id int, order_status varchar(100), shipping_detail varchar(100));


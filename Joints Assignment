#Left join
select * from shopping left join orders on shopping.product_id = orders.product_id;

#Right join
select * from shopping right join orders on shopping.product_id = orders.product_id;

#Inner join
select * from shopping inner join orders on shopping.product_id = orders.product_id;

#Outer join
select * from shopping left join orders on shopping.product_id = orders.product_id
UNION
select * from shopping right join orders on shopping.product_id = orders.product_id;

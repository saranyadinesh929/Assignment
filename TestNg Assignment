Write a TestNG program to run the flow as EmployeeRegister -> EmployeeLogin -> EmployeeTask->EmployeeSalary
Each method depends on the previous method and priority should be set as show in the order of flow

package assignment;
import org.testng.annotations.Test;

public class TestngAssignment {

	@Test(priority=1)
	public void employeeRegister() {
		System.out.println("Employee registration completed");
	}
	
	@Test(priority=2, dependsOnMethods="employeeRegister")
	public void employeeLogin() {
		System.out.println("Employee logged in successfully");
	}
	
	@Test(priority=3, dependsOnMethods="employeeLogin")
	public void employeeTask() {
		System.out.println("Task Assigned");		
	}
	
	@Test(priority=4, dependsOnMethods="employeeTask")
	public void employeeSalary() {
		System.out.println("Employee salary credited");
	}
}

Write a program to print only numbers divisible by 5 using jumping statement and looping statement

package Assignment;
public class JumpingstatementAssignment {

	public static void main(String[] args) {
		for (int i=1;i<=50;i++) {
			if(i%5!=0) {
			continue;
		} else {
			System.out.println(i);
		}
	}
	}
}

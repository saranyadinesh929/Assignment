1. Write a program to find whether the given number is even or odd.
For eg: User inputs 8, the output should be "The number 8 is even"

package Assignment;
import java.util.Scanner;
public class ControlstatementsAssignments {

	public static void main(String[] args) {
		Scanner scan = new Scanner(System.in);
		System.out.print("Enter the number: ");
		int numb = scan.nextInt();
		if(numb%2==0) {
			System.out.print("the number " +numb+ " is even");
		}
		else {
			System.out.print("the number " +numb+ " is odd");
		}
		scan.close();
	}
}


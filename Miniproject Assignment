Navigate to https://www.globalsqa.com/angularJs-protractor/BankingProject/#/login
Automate "Bank Manager Login" flow
Note: U have to first "Add Customer" details to "Open Account" where u can select the newly added customer. Then u can view that in "Customers" section
So create seperate methods and call it from main method.

package SeleniumAssignment;

import java.io.File;
import java.io.IOException;
import java.time.Duration;
import java.util.List;

import org.apache.commons.io.FileUtils;
import org.openqa.selenium.Alert;
import org.openqa.selenium.By;
import org.openqa.selenium.OutputType;
import org.openqa.selenium.TakesScreenshot;
import org.openqa.selenium.WebDriver;
import org.openqa.selenium.WebElement;
import org.openqa.selenium.chrome.ChromeDriver;
import org.openqa.selenium.support.ui.Select;

public class MiniProjectAssignment {
	
	WebDriver driver;
	WebElement firstName, lastName, postCode, dropdown, currency, table;
	Alert popup;
	
	public void captureScreenshot(String filename) throws IOException {
		
		TakesScreenshot ts =(TakesScreenshot) driver;
		File src = ts.getScreenshotAs(OutputType.FILE);
		File dest =new File("C:\\Users\\sarob\\eclipse-workspace\\selenium\\Screenshot\\" +filename+".png");
		FileUtils.copyFile(src, dest);
		System.out.println("Screenshot taken for " +filename);
		}
	
	public void lauchSite() throws IOException {
		
		String url ="https://www.globalsqa.com/angularJs-protractor/BankingProject/#/login";
		driver = new ChromeDriver();
		driver.get(url);
		driver.manage().window().maximize();
		System.out.println("Website launched");
		driver.manage().timeouts().implicitlyWait(Duration.ofSeconds(10)); //implicit wait
		captureScreenshot("lauchSite");
		}
	
	public void addCustomer() throws IOException {
		
		driver.findElement(By.xpath("//button[text()='Bank Manager Login']")).click();
		driver.findElement(By.cssSelector("button[ng-click='addCust()']")).click();
		firstName = driver.findElement(By.xpath("//div[1]/input"));
		lastName = driver.findElement(By.xpath("//div[2]/input"));
		postCode = driver.findElement(By.xpath("//div[3]/input"));
		firstName.sendKeys("Saranya");
		lastName.sendKeys("Jayaraman");
		postCode.sendKeys("600024");
		driver.findElement(By.cssSelector("button[type='submit']")).click();
		popup =driver.switchTo().alert();
		popup.accept();
		captureScreenshot("addCustomer");
		System.out.println("New customer added");
	}
	
	public void openAccount() throws IOException {
		
		driver.findElement(By.cssSelector("button[ng-click='openAccount()']")).click();
		dropdown = driver.findElement(By.id("userSelect"));
		Select selectOpt = new Select(dropdown);
		selectOpt.selectByVisibleText("Saranya Jayaraman");
		currency = driver.findElement(By.id("currency"));
		Select selectCur = new Select(currency);
		selectCur.selectByValue("Rupee");
		driver.findElement(By.cssSelector("button[type='submit']")).click();
		popup.accept();
		captureScreenshot("openAccount");
		System.out.println("Account opened");
	}

	public void customer() {
		
		driver.findElement(By.cssSelector("button[ng-click='showCust()']")).click();
		table = driver.findElement(By.tagName("table"));
		List<WebElement> row = table.findElements(By.tagName("tr"));
		
		for (WebElement rows:row) {
			List<WebElement> data = rows.findElements(By.tagName("td"));
			for(WebElement datas:data) {
				System.out.print(datas.getText()+ "  ");
			}
			System.out.println();
		}
	}
	
	public static void main(String[] args) throws IOException {
	MiniProjectAssignment project = new MiniProjectAssignment();
	project.lauchSite();
	project.addCustomer();
	project.openAccount();
	project.customer();
	project.driver.close();
	
	}

}

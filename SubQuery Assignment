Create a table for students which should contain the following columns
id, name, subject,mark,course

use saro;
create table Students (
    id int auto_increment primary key,
    name varchar(50),
    subject varchar(50),
    mark int,
    course varchar(50)
);
INSERT INTO Students(name, subject, mark, course) VALUES ( 'Saranya', 'Java', 85, 'Automation'), ( 'Divya', 'SQL', 45, 'Database'),
('Sharmi', 'Selenium', 75, 'Automation'), ( 'Sundari', 'Python', 55, 'Programming'),( 'Gnanam', 'Java', 35, 'Programming');

1) Write subquery which should return student details whose mark should be grater than average.

select * from Students where mark >(select avg(mark) from students);

output:
1	Saranya	Java	85	Automation
3	Sharmi	Selenium	75	Automation

2) Write a multi row subquery which should contain students with marks > 50

select * from students where id in (select id from students where mark >50);

output:

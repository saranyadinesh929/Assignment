Navigate to http://uitestingplayground.com/autowait
Click "Apply 5s" button given
Click the blue "Button" after the wait time

package SeleniumAssignment;

import java.time.Duration;
import org.openqa.selenium.By;
import org.openqa.selenium.WebDriver;
import org.openqa.selenium.WebElement;
import org.openqa.selenium.chrome.ChromeDriver;
import org.openqa.selenium.support.ui.ExpectedConditions;
import org.openqa.selenium.support.ui.WebDriverWait;

public class SynchronizationAssignment {

	public static void main(String[] args){
	String url ="http://uitestingplayground.com/autowait";
	WebDriver driver = new ChromeDriver();
	driver.get(url);
	driver.manage().window().maximize();
	driver.findElement(By.id("applyButton5")).click();
	WebDriverWait expwait = new WebDriverWait(driver, Duration.ofSeconds(10));
	WebElement exp = expwait.until(ExpectedConditions.elementToBeClickable(By.id("target")));
	exp.click();
	}

}
